{
  manifest_version: "0.1.0",
  config: {
    openai_api_key: { type: "string", secret: true },
    model: { type: "string", default: "gpt-5.4-mini" },
  },
  program: {
    image: "alinabelko/agentx-research:latest",
    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      AGENT_MODEL: "gpt-5.4-mini",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9019 },
      ],
    },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
}
